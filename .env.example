# Database (SQLite for dev, Postgres for prod)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/stride?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"

# Server
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# OAuth (optional, defer to later phase)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# File Storage (local for dev, S3 for prod)
UPLOAD_DIR="./uploads"
# AWS_S3_BUCKET=""
# AWS_S3_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# Email (console for dev, Resend for prod)
# RESEND_API_KEY=""
